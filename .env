# ============================================================
# TechShop Backend — Variables d'environnement
# Fichier : .env
# IMPORTANT : Ne jamais versionner ce fichier (ajouté dans .gitignore)
# ============================================================

# Serveur
PORT=3001
NODE_ENV=development

# Base de données MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/techshop_db

# JWT (JSON Web Token) — clé secrète de signature
JWT_SECRET=techshop_secret_jwt_isep_thies_2025
JWT_EXPIRES_IN=7d

# Mot de passe admin par défaut (généré lors du seed)
ADMIN_EMAIL=admin@techshop.sn
ADMIN_PASSWORD=Admin@2025
